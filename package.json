{
  "name": "visual-voice-control-system",
  "version": "1.0.0",
  "description": "Smart-home control demo with unified dispatch across GUI, Chinese voice, text commands, and gestures.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "vite --host 127.0.0.1",
    "dev": "vite --host 127.0.0.1",
    "assets:build": "node scripts/optimize-landing-assets.mjs && node scripts/build-control-room-v2-assets.mjs",
    "assets:console": "node scripts/capture-console-preview.mjs",
    "build": "npm run assets:build && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "node scripts/check-syntax.mjs",
    "test": "node --test",
    "test:python": "python -m unittest discover -s python_tests -p \"test_*.py\"",
    "test:e2e": "node scripts/run-e2e.mjs",
    "voice:dev": "python -m voice_service",
    "verify": "npm run check && npm test && npm run test:python && npm run build && npm run test:e2e"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "swiper": "^12.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitejs/plugin-react": "^6.0.2",
    "sharp": "^0.35.1",
    "vite": "^8.0.16"
  }
}
